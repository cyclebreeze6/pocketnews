rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Files are publicly readable for channel logos, etc.
    // Write operations are restricted to admin users.
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && 
                     request.resource.size <= 200 * 1024 * 1024 &&
                     (
                       exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) ||
                       (firestore.get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isCreator == true)
                     );
    }
  }
}
