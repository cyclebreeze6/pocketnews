
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /* =================================
       HELPER FUNCTIONS
    ================================= */
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isAdmin() {
      // User is an admin if the isAdmin flag is true on their user profile.
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isAdmin', false) == true;
    }
    
    function isCreator() {
      // User is a creator if the isCreator flag is true on their user profile.
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isCreator', false) == true;
    }

    function isCreatorOrAdmin() {
      return isCreator() || isAdmin();
    }

    /* =================================
       PUBLIC CONTENT COLLECTIONS
       Readable by all, writable by Creators/Admins.
    ================================= */
    match /channels/{channelId} {
      allow get, list: if true;
      allow write: if isCreatorOrAdmin();
    }

    match /videos/{videoId} {
      allow get, list: if true;
      allow write: if isCreatorOrAdmin();
    }

    match /shorts/{shortId} {
      allow get, list: if true;
      allow write: if isCreatorOrAdmin();
    }

    match /categories/{categoryId} {
      allow get, list: if true;
      allow write: if isCreatorOrAdmin();
    }

    /* =================================
       USER-SPECIFIC COLLECTIONS
    ================================= */
    match /users/{userId} {
      // Admins can get any user's profile. Others can only get their own.
      allow get: if isOwner(userId) || isAdmin();
      // Admins can list all users.
      allow list: if isAdmin();
      
      // A user can create and delete their own document.
      allow create, delete: if isOwner(userId);
      // A user can update their own document. Admins can update any user document.
      allow update: if isOwner(userId) || isAdmin();

      // Subcollections are private to the owner.
      match /history/{docId}        { allow read, write, delete: if isOwner(userId); }
      match /fcmTokens/{tokenId}    { allow read, write, delete: if isOwner(userId); }
      match /collections/{collectionId} { allow read, write, delete: if isOwner(userId); }
    }
    
    /* =================================
       ADMIN & SYSTEM COLLECTIONS
    ================================= */

    // Any signed-in user can submit a report.
    // Only Creators/Admins can read or manage reports.
    match /reports/{reportId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isCreatorOrAdmin();
    }
  }
}
