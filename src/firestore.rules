
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------
    // Helper Functions
    // --------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      // Admin role is determined by the existence of a document in the 'roles_admin' collection.
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }
    
    function isCreator() {
        // Creator role is determined by a boolean flag on the user's profile.
        return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isCreator == true;
    }
    
    function canWriteContent() {
        // Only admins or creators can write content.
        return isAdmin() || isCreator();
    }

    // --------------------------------
    // Public Content Collections
    // --------------------------------
    match /channels/{channelId} {
      // Anyone can read channels.
      allow get, list: if true;
      // Only admins and creators can write.
      allow write: if canWriteContent();
    }

    match /videos/{videoId} {
      // Anyone can read videos.
      allow get, list: if true;
      // Only admins and creators can write.
      allow write: if canWriteContent();
    }
    
    match /shorts/{shortId} {
      // Anyone can read shorts.
      allow get, list: if true;
      // Only admins and creators can write.
      allow write: if canWriteContent();
    }

    match /categories/{categoryId} {
      // Anyone can read categories.
      allow get, list: if true;
      // Only admins can write categories.
      allow write: if isAdmin();
    }

    // --------------------------------
    // User-specific Collections
    // --------------------------------
    match /users/{userId} {
      // Users can read their own profile, admins can read any profile.
      allow get: if isOwner(userId) || isAdmin();
      // Only admins can list all users.
      allow list: if isAdmin();
      // Users can create their own profile.
      allow create: if isOwner(userId);
      // Users can update their own profile, admins can update any.
      allow update: if isOwner(userId) || isAdmin();
      // Users can delete their own profile, admins can delete any.
      allow delete: if isOwner(userId) || isAdmin();

      // Subcollections for a user are only accessible by that user.
      match /history/{docId} {
         allow read, write, delete: if isOwner(userId);
      }
      match /fcmTokens/{tokenId} {
        allow read, write, delete: if isOwner(userId);
      }
      match /collections/{collectionId} {
        allow read, write, delete: if isOwner(userId);
      }
    }
    
    // --------------------------------
    // Admin & System Collections
    // --------------------------------
    match /roles_admin/{userId} {
      // Only admins can manage admin roles.
      allow read, write: if isAdmin();
      // Allow initial self-promotion for designated admin emails.
      allow create: if isOwner(userId) && (request.auth.token.email == 'valentinoboss18@gmail.com' || request.auth.token.email == 'emmachukwunonye54@gmail.com');
    }

    match /reports/{reportId} {
      // Only admins can view reports.
      allow get, list: if isAdmin();
      // Any signed-in user can create a report.
      allow create: if isSignedIn();
      // Only admins can modify or delete reports.
      allow update, delete: if isAdmin();
    }
    
    match /email_queue/{emailId} {
      // No client access to the email queue.
      allow read, write: if false;
    }
  }
}
