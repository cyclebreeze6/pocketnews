rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------
    // Helper Functions
    // --------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --------------------------------
    // Public Content Collections
    // --------------------------------
    match /channels/{channelId} {
      allow get, list: if true;
      allow write: if isSignedIn(); // Simplified for debugging
    }
    match /videos/{videoId} {
      allow get, list: if true;
      allow write: if isSignedIn(); // Simplified for debugging
    }
    match /shorts/{shortId} {
      allow get, list: if true;
      allow write: if isSignedIn(); // Simplified for debugging
    }
    match /categories/{categoryId} {
      allow get, list: if true;
      allow write: if isSignedIn(); // Simplified for debugging
    }

    // --------------------------------
    // User-specific Collections
    // --------------------------------
    match /users/{userId} {
      // A user can always manage their own document.
      allow get, create, update, delete: if isOwner(userId);
      
      // Allow any signed-in user to list users for now to avoid read errors.
      allow list: if isSignedIn();

      // Subcollections are private to the owner.
      match /history/{docId}        { allow read, write, delete: if isOwner(userId); }
      match /fcmTokens/{tokenId}    { allow read, write, delete: if isOwner(userId); }
      match /collections/{collectionId} { allow read, write, delete: if isOwner(userId); }
    }
    
    // --------------------------------
    // Admin & System Collections
    // --------------------------------
    match /reports/{reportId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isSignedIn(); // Simplified for debugging
    }
    
    match /email_queue/{emailId} {
      // Only backend processes can access this collection.
      allow read, write: if false;
    }
  }
}
