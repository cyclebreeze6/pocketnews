rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --------------------------------
    // Helper Functions
    // --------------------------------
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // This function is safe to call because any signed-in user
    // is explicitly allowed to `get` their own user document.
    function isAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }
    
    function isCreator() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isCreator == true;
    }
    
    function canWriteContent() {
        return isAdmin() || isCreator();
    }

    // --------------------------------
    // Public Content Collections
    // --------------------------------
    match /channels/{channelId} {
      allow get, list: if true;
      allow write: if canWriteContent();
    }
    match /videos/{videoId} {
      allow get, list: if true;
      allow write: if canWriteContent();
    }
    match /shorts/{shortId} {
      allow get, list: if true;
      allow write: if canWriteContent();
    }
    match /categories/{categoryId} {
      allow get, list: if true;
      allow write: if isAdmin();
    }

    // --------------------------------
    // User-specific Collections
    // --------------------------------
    match /users/{userId} {
      // A user can ALWAYS get their own document. This is critical to making isAdmin() safe.
      allow get, create, update, delete: if isOwner(userId);
      
      // An admin can list users for the admin panel. This is a separate rule.
      allow list: if isAdmin();

      // Subcollections are private to the owner.
      match /history/{docId}        { allow read, write, delete: if isOwner(userId); }
      match /fcmTokens/{tokenId}    { allow read, write, delete: if isOwner(userId); }
      match /collections/{collectionId} { allow read, write, delete: if isOwner(userId); }
    }
    
    // --------------------------------
    // Admin & System Collections
    // --------------------------------
    match /reports/{reportId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isAdmin();
    }
    
    match /email_queue/{emailId} {
      // Only backend processes can access this collection.
      allow read, write: if false;
    }
  }
}
