
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    /* =================================
       HELPER FUNCTIONS
    ================================= */

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isDesignatedAdmin(email) {
      return email == 'valentinoboss18@gmail.com' || email == 'emmachukwunonye54@gmail.com';
    }
    
    function isAdmin() {
      // User is an admin if their UID is in the roles_admin collection
      // OR they are one of the designated super-admins by email.
      return exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid)) 
             || isDesignatedAdmin(request.auth.token.email);
    }
    
    function isCreator() {
      // User is a creator if the isCreator flag is true on their user profile.
      // A get on one's own user document is permitted.
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('isCreator', false) == true;
    }

    function isCreatorOrAdmin() {
      return isCreator() || isAdmin();
    }

    /* =================================
       PUBLIC CONTENT COLLECTIONS
       Readable by all, writable by Creators/Admins.
    ================================= */
    match /channels/{channelId} {
      allow read: if true;
      allow write: if isCreatorOrAdmin();
    }

    match /videos/{videoId} {
      allow read: if true;
      allow write: if isCreatorOrAdmin();
    }

    match /shorts/{shortId} {
      allow read: if true;
      allow write: if isCreatorOrAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isCreatorOrAdmin();
    }

    /* =================================
       USER-SPECIFIC COLLECTIONS
    ================================= */
    match /users/{userId} {
      // A user can get their own profile. Admins can get any user's profile.
      allow get: if isOwner(userId) || isAdmin();
      
      // Admins can list all users.
      allow list: if isAdmin();

      // A user can create, update, and delete their own document.
      allow create, update, delete: if isOwner(userId);

      // Subcollections are private to the owner.
      match /history/{docId}        { allow read, write, delete: if isOwner(userId); }
      match /fcmTokens/{tokenId}    { allow read, write, delete: if isOwner(userId); }
      match /collections/{collectionId} { allow read, write, delete: if isOwner(userId); }
    }
    
    /* =================================
       ADMIN & SYSTEM COLLECTIONS
    ================================= */

    // Any signed-in user can submit a report.
    // Only Creators/Admins can read or manage reports.
    match /reports/{reportId} {
      allow create: if isSignedIn();
      allow read, update, delete: if isCreatorOrAdmin();
    }
    
    // Admin role documents.
    match /roles_admin/{userId} {
      // An authenticated user can check their own admin status. Admins can list all admins.
      allow get: if isOwner(userId);
      allow list: if isAdmin();

      // Allow existing admins to grant roles.
      // Designated super-admins can also grant themselves the role.
      allow write: if isAdmin() || (isOwner(userId) && isDesignatedAdmin(request.auth.token.email));
    }
  }
}

    