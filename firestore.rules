
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions for reusable logic

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid));
    }
    
    function isCreator() {
        return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isCreator == true;
    }
    
    function canCreateContent() {
        return isAdmin() || isCreator();
    }

    function isExistingDoc() {
      return resource != null;
    }

    function isExistingOwner(userId) {
      return isOwner(userId) && isExistingDoc();
    }

    function isExistingAdmin() {
      return isAdmin() && isExistingDoc();
    }

    function userHasConsistentId(userId) {
      return request.resource.data.id == userId;
    }

    function userCanUpdateSelf() {
        // List of fields a user is allowed to update on their own profile.
        let allowedFields = ['displayName', 'avatar', 'preferredCategories'];
        // All incoming fields must be in the allowed list.
        let allFieldsAreAllowed = request.resource.data.keys().hasOnly(allowedFields);

        return allFieldsAreAllowed;
    }

    function videoChannelIsImmutable() {
      return request.resource.data.channelId == resource.data.channelId;
    }
    
    function isReportOwner(reportId) {
        return isSignedIn() && get(/databases/$(database)/documents/reports/$(reportId)).data.userId == request.auth.uid;
    }

    function isSanitizedString(text) {
      // Allow empty strings, but if text is not empty, sanitize it.
      return text == "" || !text.matches('[<>&;{}]');
    }

    // Security rules for collections

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && userHasConsistentId(userId);
      // An admin can update any user's document. A user can only update their own with limitations.
      allow update: if (isExistingOwner(userId) && userCanUpdateSelf()) || isExistingAdmin();
      allow delete: if isExistingOwner(userId) || isExistingAdmin();

      match /history/{videoId} {
         allow read, write, delete: if isOwner(userId);
      }
      
      // Users can manage their own FCM tokens.
      match /fcmTokens/{tokenId} {
        allow read, write, delete: if isOwner(userId);
      }
       // Users can manage their own collections
      match /collections/{collectionId} {
        allow read, write, delete: if isOwner(userId);
      }
    }

    match /channels/{channelId} {
      // All signed-in users can view channels
      allow get, list: if isSignedIn();
      // Only Admins or Creators can manage channels.
      allow create, update: if canCreateContent();
      allow delete: if isAdmin();
    }
    
    match /videos/{videoId} {
      // All signed-in users can view videos
      allow get, list: if isSignedIn();
      allow create: if canCreateContent();
      allow update: if (isAdmin() || isCreator()) && isExistingDoc() && videoChannelIsImmutable();
      allow delete: if (isAdmin() || isCreator()) && isExistingDoc();
    }

    match /shorts/{shortId} {
      allow get: if true;
      allow create, update, delete: if canCreateContent();
    }
    match /shorts {
        allow list: if true;
    }

    match /categories/{categoryId} {
      // All signed-in users can view categories
      allow get, list: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }
    
    match /reports/{reportId} {
        allow get, list: if isAdmin();
        // Any signed-in user can create a report, but with data validation.
        allow create: if isSignedIn()
                      && request.resource.data.userId == request.auth.uid
                      && isSanitizedString(request.resource.data.details);
        allow update: if isAdmin();
        allow delete: if isAdmin() || isReportOwner(reportId);
    }
    
    match /email_queue/{emailId} {
        allow read, write: if isAdmin(); // Only admins (backend) can manage the queue
    }

    // This rule allows collection group queries on the 'videos' collection.
    // Any authenticated user can list videos, which is necessary for the homepage feed.
    match /{path=**}/videos/{videoId} {
      allow read: if isSignedIn();
    }

    match /roles_admin/{userId} {
      // For bootstrapping, allow a user to make themselves an admin.
      // This should be locked down in production to `allow read, write: if false;`
      allow create: if isOwner(userId);
      allow read, update, delete: if false;
    }
  }
}
