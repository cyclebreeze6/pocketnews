
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check for admin or creator role
    function isCreatorOrAdmin() {
      return request.auth != null && (
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isCreator == true
      );
    }

    // Helper function to check for admin role
    function isAdmin() {
      return request.auth != null &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }
    
    // User can read/write their own profile data. Admins can read/write any user's profile.
    match /users/{userId} {
      allow read, update: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow create: if request.auth != null;
      allow delete: if request.auth != null && (request.auth.uid == userId || isAdmin());

      // User can manage their own data subcollections.
      match /collections/{collectionId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /history/{videoId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /fcmTokens/{tokenId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      match /followedChannels/{channelId} {
        allow read, write, delete: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Public content collections: anyone can read.
    // This uses a collection group query format to support indexed queries across the app.
    match /{path=**}/videos/{videoId} {
      allow get, list: if true;
      allow write: if isCreatorOrAdmin();
    }

    match /channels/{channelId} {
      allow get, list: if true;
      allow write: if isCreatorOrAdmin();
    }
    
    match /shorts/{shortId} {
      allow get, list: if true;
      allow write: if isCreatorOrAdmin();
    }
    
    match /categories/{categoryId} {
      allow get, list: if true;
      allow write: if isCreatorOrAdmin();
    }

    // Reports can be created by authenticated (non-anonymous) users, but only read/managed by admins.
    match /reports/{reportId} {
      allow create: if request.auth != null && request.auth.token.firebase.sign_in_provider != "anonymous";
      allow read, update, delete: if isAdmin();
    }
    
    // The roles_admin collection is managed internally but should only be touched by admins.
    match /roles_admin/{userId} {
        allow read, write: if isAdmin();
    }
  }
}
